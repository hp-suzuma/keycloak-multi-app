      "attributes": {
        "post.logout.redirect.uris": "https://global.example.com/*"
      },
      "redirectUris": [
        "https://a.example.com/auth/callback"
      ],
      "webOrigins": [
        "https://a.example.com"
      ],
      "standardFlowEnabled": true,
