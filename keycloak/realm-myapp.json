      "clientId": "global-login",
      "name": "Global BFF",
      "enabled": true,
      "publicClient": false,
      "secret": "global-secret",
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "https://global.example.com/*"
      },
      "redirectUris": [
        "https://global.example.com/auth/callback"
      ],
      "webOrigins": [
        "https://global.example.com"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false
    },
    {
      "clientId": "app-a",
      "name": "Site A BFF",
      "enabled": true,
      "publicClient": false,
      "secret": "app-a-secret",
