APP_NAME=ap-backend
APP_URL=http://localhost:8000

# Keep AP backend data separate from the existing backend/BFF DB.
DB_DATABASE=ap_server

# Default to the shared login client. Change this if you validate with app-a/app-b tokens instead.
KEYCLOAK_ISSUER=https://keycloak.example.com/realms/myapp
KEYCLOAK_CLIENT_ID=global-login
KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/myapp/protocol/openid-connect/certs
